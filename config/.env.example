# Enable Banking (enablebanking.com → register an application)
# APP_ID: UUID shown in the dashboard after registration
# PRIVATE_KEY_PATH: path to the RSA private key PEM downloaded at registration
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_PRIVATE_KEY_PATH=config/private_key.pem

# Compilati automaticamente da src/auth/enable_banking_auth.py dopo il primo login
ENABLE_BANKING_SESSION_ID=
ENABLE_BANKING_ACCESS_TOKEN=
ENABLE_BANKING_ACCOUNT_IDS=   # JSON array: ["uid1","uid2"]

# Claude API (anthropic.com)
ANTHROPIC_API_KEY=sk-ant-

# Postgres locale (usato da Docker Compose)
DB_PASSWORD=cambia_questa_password

# Impostata automaticamente da docker-compose per puntare al container db
# In locale senza Docker: postgresql://user:<DB_PASSWORD>@localhost:5432/finance
DATABASE_URL=

# Pipeline
FETCH_DAYS_BACK=90
LOG_LEVEL=INFO
